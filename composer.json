{
    "name": "ptadmin/admin-skeleton",
    "type": "project",
    "description": "PTAdmin skeleton application for composer create-project.",
    "keywords": [
        "framework",
        "laravel",
        "企业建站",
        "快速开发"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Zane",
            "email": "873934580@qq.com"
        }
    ],
    "require": {
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-zip": "*",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "laravel/framework": "^8.75",
        "laravel/serializable-closure": "^1.3",
        "laravel/tinker": "^2.5",
        "php": "^7.4|^8.0",
        "ptadmin/admin": "^1.0"
    },
    "require-dev": {
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^5.10",
        "phpunit/phpunit": "^9.5.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Addon\\": "addons/"
        },
        "files": []
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "ptadmin-skeleton:prepare-env": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "pre-autoload-dump": [
            "@ptadmin-skeleton:prepare-env"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@ptadmin-skeleton:prepare-env"
        ],
        "post-update-cmd": [
            "@ptadmin-skeleton:prepare-env"
        ],
        "post-root-package-install": [
            "@ptadmin-skeleton:prepare-env"
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan vendor:publish --provider=\"PTAdmin\\Admin\\Providers\\PTAdminServiceProvider\" --tag=ptadmin-config --ansi --force",
            "@php artisan vendor:publish --provider=\"PTAdmin\\Admin\\Providers\\PTAdminServiceProvider\" --tag=ptadmin-migrations --ansi --force"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
